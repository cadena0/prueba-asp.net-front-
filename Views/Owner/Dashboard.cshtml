@{
    ViewData["Title"] = "Dashboard Propietario";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Panel de Propietario</h2>
        <a href="/Property/Create" class="btn btn-primary">+ Nueva Propiedad</a>
    </div>

    <h4 class="mt-4">Mis Propiedades y Reservas</h4>
    <div id="ownerData" class="mt-3">
        Cargando datos del propietario...
    </div>
</div>

@section Scripts {
    <script src="/js/api.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            if ((window.getUserRole ? window.getUserRole() : null) !== 'OWNER') {
                window.location.href = '/Auth/Login';
                return;
            }

            try {
                const res = await fetchApi('/reservations/metrics');
                const metrics = await res.json();

                const container = document.getElementById('ownerData');
                if (!res.ok) {
                    container.innerHTML = '<div class="alert alert-danger">Error al cargar datos.</div>';
                    return;
                }

                if (metrics.totalReservations === 0) {
                    container.innerHTML = '<p>Aún no tienes reservaciones en tus propiedades.</p>';
                    return;
                }

                let html = `
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">Total Propiedades</h5>
                                    <p class="display-4">${metrics.totalProperties}</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">Total Reservas</h5>
                                    <p class="display-4">${metrics.totalReservations}</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card">
                                <div class="card-body">
                                    <h5 class="card-title">Ganancias</h5>
                                    <p class="display-4">$${metrics.totalEarnings?.toLocaleString()}</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <h5>Reservas por propiedad</h5>
                    <ul class="list-group">
                `;

                metrics.properties?.forEach(p => {
                    html += `
                        <li class="list-group-item">
                            <strong>${p.title}</strong> - 
                            ${p.reservationCount} reservas - 
                            Ganancias: $${p.earnings?.toLocaleString()}
                        </li>
                    `;
                });
                html += '</ul>';
                container.innerHTML = html;

            } catch (error) {
                console.error(error);
                document.getElementById('ownerData').innerHTML = '<div class="alert alert-danger">Error de conexión.</div>';
            }
        });
    </script>
}