@{
    ViewData["Title"] = "Dashboard Propietario";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Panel de Propietario</h2>
        <a href="/Property/Create" class="btn btn-primary">+ Nueva Propiedad</a>
    </div>

    <h4 class="mt-4">Mis Propiedades y Reservas</h4>
    <div id="ownerData" class="mt-3">
        Cargando datos del propietario...
    </div>
</div>

@section Scripts {
    <script src="/js/api.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            if ((window.getUserRole ? window.getUserRole() : null) !== 'OWNER') {
                window.location.href = '/Auth/Login';
                return;
            }

            try {
                const res = await fetchApi('/reservations/metrics');
                const metrics = await res.json();
                
                const container = document.getElementById('ownerData');
                if(reservations.length === 0) {
                    container.innerHTML = '<p>Aún no tienes reservaciones en tus propiedades.</p>';
                    return;
                }

                let html = '<ul class="list-group">';
                reservations.forEach(r => {
                    html += `
                        <li class="list-group-item">
                            <strong>${r.property.title}</strong> - 
                            Reserva del ${new Date(r.startDate).toLocaleDateString()} 
                            al ${new Date(r.endDate).toLocaleDateString()} 
                            (Cliente ID: ${r.userId})
                        </li>
                    `;
                });
                html += '</ul>';
                container.innerHTML = html;

            } catch (error) {
                console.error(error);
            }
        });
    </script>
}