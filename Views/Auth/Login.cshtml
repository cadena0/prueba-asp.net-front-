@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="auth-card mx-auto my-5">
    <div class="text-center mb-4">
        <h1 class="h3 fw-bold">Bienvenido de vuelta</h1>
        <p class="text-muted">Accede a tu cuenta para comenzar a reservar.</p>
    </div>

    <div id="authMessage"></div>

    <form id="loginForm">
        <div class="form-group mb-3">
            <label class="form-label">Correo</label>
            <input type="email" id="email" class="form-control" placeholder="ejemplo@correo.com" required />
            <div class="invalid-feedback" id="emailError"></div>
        </div>
        <div class="form-group mb-4">
            <label class="form-label">Contraseña</label>
            <input type="password" id="password" class="form-control" placeholder="Tu contraseña" required />
            <div class="invalid-feedback" id="passwordError"></div>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2">Ingresar</button>
    </form>

    <p class="text-center text-muted mt-4">¿No tienes cuenta? <a href="/Auth/Register">Regístrate aquí</a></p>
</div>

@section Scripts {
    <script src="/js/api.js" asp-append-version="true"></script>
    <script src="/js/auth.js" asp-append-version="true"></script>
}